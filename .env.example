# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
# Use * for development, specific domain for production
CORS_ORIGIN=*

# Cache Configuration (in milliseconds)
# Default: 5 minutes (300000ms)
CACHE_TTL=300000

# Cache cleanup interval (in milliseconds)
# Default: 10 minutes (600000ms)
CACHE_CLEANUP_INTERVAL=600000

# Rate Limiting
# Window duration (in milliseconds)
# Default: 15 minutes (900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
# Default: 100
RATE_LIMIT_MAX_REQUESTS=100

# Request timeout (in milliseconds)
# Default: 10 seconds (10000ms)
REQUEST_TIMEOUT=10000

# Maximum retry attempts for failed requests
# Default: 3
MAX_RETRIES=3

# Retry delay base (in milliseconds)
# Default: 1 second (1000ms)
# Actual delay uses exponential backoff
RETRY_DELAY=1000
