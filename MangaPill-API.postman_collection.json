{
  "info": {
    "name": "MangaPill API Scraper",
    "description": "Complete collection of MangaPill API endpoints for testing and development",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Documentation",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the API server is running and healthy"
          }
        },
        {
          "name": "API Documentation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/docs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "docs"]
            },
            "description": "Get detailed API documentation with all endpoints"
          }
        },
        {
          "name": "Root - API Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Get API overview and quick reference"
          }
        }
      ]
    },
    {
      "name": "Homepage",
      "item": [
        {
          "name": "Get Homepage Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/homepage",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homepage"]
            },
            "description": "Get homepage data including featured chapters, new chapters, trending manga, and latest news"
          }
        }
      ]
    },
    {
      "name": "Manga",
      "item": [
        {
          "name": "Get Manga Details - Chainsaw Man",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manga/723",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manga", "723"]
            },
            "description": "Get detailed information about Chainsaw Man (ID: 723)"
          }
        },
        {
          "name": "Get Manga Details - One Piece",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manga/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manga", "2"]
            },
            "description": "Get detailed information about One Piece (ID: 2)"
          }
        },
        {
          "name": "Get Manga Details - Berserk",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manga/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manga", "1"]
            },
            "description": "Get detailed information about Berserk (ID: 1)"
          }
        },
        {
          "name": "Get New Manga - Page 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manga/new?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manga", "new"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            },
            "description": "Get newly added manga (first page)"
          }
        },
        {
          "name": "Get Random Manga",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manga/random",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manga", "random"]
            },
            "description": "Get a random manga recommendation"
          }
        }
      ]
    },
    {
